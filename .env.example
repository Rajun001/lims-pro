# LIMS-PRO Configuración de Entorno

# --- CONFIGURACIÓN DEL FRONTEND (Vite) ---
# URL pública de la API REST del LIMS. 
# En desarrollo: http://localhost:3001
# En producción: http://<IP_DE_TU_VM>:3001 (o tu dominio público)
VITE_API_URL=http://localhost:3001

# --- CONFIGURACIÓN DEL BACKEND API (Express) ---
# Puerto en el que corre la API de Express
PORT=3001

# --- CONFIGURACIÓN DEL TCP ANALYZER SERVICE ---
# Puerto en el que escucha conexiones TCP HL7/ASTM de los analizadores clínicos
ANALYZER_PORT=9000

# --- CONFIGURACIÓN DE LA BASE DE DATOS (Prisma) ---
# Ubicación del archivo de base de datos SQLite para Prisma
DATABASE_URL="file:./dev.db"
